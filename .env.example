# Copier ce fichier en ".env" puis modifier ORACLE_CLIENT_LIB (seul chemin a renseigner
# si vous n'avez pas deplace le ZIP : mettez le dossier ou vous avez dezippe, ex. Downloads).
#
# Windows + Instant Client : les .dll Oracle sont compilees avec Visual C++. Si au lancement
# vous voyez "VCRUNTIME140.dll" / "MSVCP140.dll" introuvable ou DPI-1047 apres chargement,
# le projet ne peut pas corriger ca : il faut le paquet gratuit "VC++ Redistributable x64"
# OU un PC qui l'a deja (souvent le cas). Sans ces DLL systeme, oci.dll ne demarre pas.

ORACLE_USER=ABS_APP
ORACLE_PASSWORD=1234
ORACLE_NAME=XE
ORACLE_HOST=localhost
ORACLE_PORT=1521

# Dossier qui CONTIENT oci.dll (pas besoin de copier les DLL ailleurs, juste ce chemin ici).
ORACLE_CLIENT_LIB=C:\chemin\vers\le\dossier_dezippe_contenant_oci_dll

# Windows : desactiver le nettoyage auto du PATH (Oracle XE 10 local) si besoin
# ORACLE_STRIP_LEGACY_PATH=0

# Django (optionnel)
# DJANGO_SECRET_KEY=changez-moi-en-production
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
